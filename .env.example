# Network Configuration
# Use the standard Neo X mainnet RPC for deployment and bot reads
NEOX_RPC_URL=https://mainnet-1.rpc.banelabs.org
# Use Neo X WSS for lower-latency pending monitoring in the bot
NEOX_WSS_URL=wss://mainnet.wss1.banelabs.org

# Wallet (for deployment)
# ⚠️ NEVER commit this to git! Keep it secure.
# Your private key without 0x prefix
PRIVATE_KEY=your_private_key_here

# Contract Address (fill these after deployment)
CONTRACT_ADDRESS=
NEXT_PUBLIC_CONTRACT_ADDRESS=

# Bot pool recycling controls (optional)
# Set to false to let bot keep winnings
BOT_RECYCLE_WINNINGS=true
# Keep this much GAS in bot wallet for future tx fees before recycling rest
BOT_GAS_RESERVE_GAS=0.05

# Optional: WalletConnect Project ID
# Get free at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
